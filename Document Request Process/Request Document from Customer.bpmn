<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="ce5fd89" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="RequestKYCDocumentCustomer" name="Request KYC Document From Customer" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:versionTag value="2" />
    </bpmn:extensionElements>
    <bpmn:intermediateCatchEvent id="Event_0fuzxwi" name="1 Day">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=&#34;After waiting 24 hours, we recieved no response to our request&#34;" target="systemNote" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0lif2nw</bpmn:incoming>
      <bpmn:outgoing>Flow_1fh6bbi</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1swt50m">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_1iq8qzb" name="Document successfuly Extracted">
      <bpmn:incoming>Flow_1yga66t</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0e29hn7" sourceRef="Activity_0bnlz7h" targetRef="Gateway_07kk52w" />
    <bpmn:sequenceFlow id="Flow_0lif2nw" sourceRef="Gateway_07kk52w" targetRef="Event_0fuzxwi" />
    <bpmn:sequenceFlow id="Flow_0sjbded" sourceRef="Gateway_07kk52w" targetRef="Event_0ogqizw" />
    <bpmn:sequenceFlow id="Flow_1h9b0i5" sourceRef="Event_0ogqizw" targetRef="Gateway_17g5n3j" />
    <bpmn:eventBasedGateway id="Gateway_07kk52w">
      <bpmn:incoming>Flow_0e29hn7</bpmn:incoming>
      <bpmn:outgoing>Flow_0sjbded</bpmn:outgoing>
      <bpmn:outgoing>Flow_0lif2nw</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_0ogqizw" name="Get Response" zeebe:modelerTemplate="io.camunda.connectors.inbound.EmailIntermediate.v1" zeebe:modelerTemplateVersion="2" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="inbound.type" value="io.camunda:connector-email-inbound:1" />
          <zeebe:property name="authentication.type" value="simple" />
          <zeebe:property name="authentication.username" value="{{secrets.EMAIL_USER_NAME_DMN}}" />
          <zeebe:property name="authentication.password" value="{{secrets.EMAIL_PASSWORD_DMN}}" />
          <zeebe:property name="data.imapConfig.imapHost" value="imap.gmail.com" />
          <zeebe:property name="data.imapConfig.imapPort" value="993" />
          <zeebe:property name="data.imapConfig.imapCryptographicProtocol" value="TLS" />
          <zeebe:property name="data.folderToListen" value="KYCDocumentRequest" />
          <zeebe:property name="data.pollingWaitTime" value="PT3S" />
          <zeebe:property name="data.pollingConfigDiscriminator" value="unseenPollingConfig" />
          <zeebe:property name="data.pollingConfig.handlingStrategy" value="READ" />
          <zeebe:property name="activationCondition" value="=not(is empty(headers[key = &#34;In-Reply-To&#34;]))" />
          <zeebe:property name="consumeUnmatchedEvents" value="false" />
          <zeebe:property name="correlationKeyExpression" value="=headers[key = &#34;In-Reply-To&#34;][1].value" />
          <zeebe:property name="deduplicationModeManualFlag" value="true" />
          <zeebe:property name="deduplicationId" value="document-request-agent-reply" />
          <zeebe:property name="deduplicationMode" value="MANUAL" />
          <zeebe:property name="resultVariable" value="documentRequestResponse" />
          <zeebe:property name="resultExpression" value="={&#10;      &#34;processedAttachments&#34;: attachments,&#10;      &#34;emailBody&#34;: plainTextBody,&#10;      &#34;emailSubject&#34;: subject&#10;  }" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0sjbded</bpmn:incoming>
      <bpmn:outgoing>Flow_1h9b0i5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_16vmsv8" messageRef="Message_089dv3v" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Activity_0bnlz7h" name="Send Request for Document" zeebe:modelerTemplate="io.camunda.connectors.email.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.EMAIL_USER_NAME_DMN}}" target="authentication.username" />
          <zeebe:input source="{{secrets.EMAIL_PASSWORD_DMN}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="smtp.gmail.com" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=587" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="TLS" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="shearsmithcamunda@gmail.com" target="data.smtpAction.from" />
          <zeebe:input source="=customerEmail" target="data.smtpAction.to" />
          <zeebe:input source="=&#34;Request for Additional Information&#34;" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="=emailBody" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.email.v1" />
          <zeebe:header key="resultVariable" value="DocumentEmailRequest" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1rt1twp</bpmn:incoming>
      <bpmn:outgoing>Flow_0e29hn7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="Event_0v3evy6" name="Upload From Portal">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="upload-form-0" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1rt1twp</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1fh6bbi" sourceRef="Event_0fuzxwi" targetRef="Gateway_0wvnjcg" />
    <bpmn:exclusiveGateway id="Gateway_0wvnjcg">
      <bpmn:incoming>Flow_1fh6bbi</bpmn:incoming>
      <bpmn:incoming>Flow_1doof8w</bpmn:incoming>
      <bpmn:incoming>Flow_0o9w2xr</bpmn:incoming>
      <bpmn:outgoing>Flow_01q8exw</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_01q8exw" sourceRef="Gateway_0wvnjcg" targetRef="Activity_1x6oq42" />
    <bpmn:sequenceFlow id="Flow_1rt1twp" sourceRef="Event_0v3evy6" targetRef="Activity_0bnlz7h" />
    <bpmn:sequenceFlow id="Flow_0o9w2xr" sourceRef="Activity_1t0mtwl" targetRef="Gateway_0wvnjcg" />
    <bpmn:serviceTask id="Activity_1t0mtwl" name="Get Data from Document" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="openai" target="provider.type" />
          <zeebe:input source="{{secrets.OpenAI}}" target="provider.openai.authentication.apiKey" />
          <zeebe:input source="gpt-4o" target="provider.openai.model.model" />
          <zeebe:input source="=&#34;You are a **Data Transformation Agent**.&#10;&#10;You&#39;ll be given some data from a document and you need to populate the following JSON Schema. Make sure you **ONLY** output the JSON object. &#10;&#10;You should first gather together all the text information you can find inside the document and then use your reasoning to order that into a complex JSON object. &#10;Also include a varialbe naming the document type and a varialbe with a short summay of the document.&#10;In cases where you don&#39;t have the data leave value field empty.&#10;&#10;Respond with only JSON. It must parse with JSON.parse().&#10;Your output MUST be valid JSON only — no text, no explanation. Validate if the resulting JSON is fully compatible with the given JSON Schema&#10;Don&#39;t use any back-ticks in your response.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;we&#39;ve requested a document &#34;" target="data.userPrompt.prompt" />
          <zeebe:input source="=document" target="data.userPrompt.documents" />
          <zeebe:input source="=parseAgent.context" target="data.context" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="json" target="data.response.format.type" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="documentDataOutput" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zzzfk8</bpmn:incoming>
      <bpmn:outgoing>Flow_0o9w2xr</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=documentRequestResponse.attachments" inputElement="document" outputCollection="detailsOfAttachments" outputElement="=documentDataOutput.responseJson" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_17g5n3j" name="Attachments found?" default="Flow_1doof8w">
      <bpmn:incoming>Flow_1h9b0i5</bpmn:incoming>
      <bpmn:outgoing>Flow_0zzzfk8</bpmn:outgoing>
      <bpmn:outgoing>Flow_1doof8w</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0zzzfk8" name="Yes" sourceRef="Gateway_17g5n3j" targetRef="Activity_1t0mtwl">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=processedAttachments != null and count(processedAttachments) &gt; 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1doof8w" name="No Attachments" sourceRef="Gateway_17g5n3j" targetRef="Gateway_0wvnjcg" />
    <bpmn:scriptTask id="Activity_1x6oq42" name="Create Response Variable">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;      &#34;emailResponseText&#34; : emailBody,&#10;      &#34;documentContent&#34; : get or else(detailsOfAttachments, &#34;No documents where sent in this communication&#34;)&#10;    }" resultVariable="responseDetails" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_01q8exw</bpmn:incoming>
      <bpmn:outgoing>Flow_1yga66t</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1yga66t" sourceRef="Activity_1x6oq42" targetRef="Event_1iq8qzb" />
  </bpmn:process>
  <bpmn:message id="Message_089dv3v" name="56a4253f-68af-4d09-91a5-d6d9e7393eeb" zeebe:modelerTemplate="io.camunda.connectors.inbound.EmailIntermediate.v1">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=DocumentEmailRequest.messageId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:error id="Error_0vw9871" name="EXTRACT_FAILED" errorCode="EXTRACT_FAILED" />
