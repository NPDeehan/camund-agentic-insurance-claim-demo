        <bpmn:incoming>Flow_0dv1xfi</bpmn:incoming>
        <bpmn:outgoing>Flow_0qfo9kt</bpmn:outgoing>
        <bpmn:outgoing>Flow_0y1tq3b</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:intermediateCatchEvent id="Event_1v7iep8" name="Case Update">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;UpdateOnTheClaim&#34; : UpdateOnTheClaim&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0y1tq3b</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_18d8q6a" messageRef="Message_1aes4cr" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_0y1tq3b" sourceRef="Gateway_1g2q0zh" targetRef="Event_1v7iep8" />
    </bpmn:adHocSubProcess>
    <bpmn:serviceTask id="Activity_0gwufmv" name="Summarize Claim Details" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="openai" target="provider.type" />
          <zeebe:input source="{{secrets.OpenAI}}" target="provider.openai.authentication.apiKey" />
          <zeebe:input source="gpt-5.1" target="provider.openai.model.model" />
          <zeebe:input source="=&#34;You are an agent running as part of a insurance claims process. At this point in the process a claim has been approved and your job is to summarize all the details of that claim based on the all the information produced by the previous agent as it worked on the problem. &#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=string(agent)" target="data.userPrompt.prompt" />
          <zeebe:input source="=summaryAgent.context" target="data.context" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="summaryAgent" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1hrpzwq</bpmn:incoming>
      <bpmn:outgoing>Flow_0y2lsci</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1hrpzwq" name="Long Term Payout" sourceRef="Gateway_11fybwb" targetRef="Activity_0gwufmv">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=claim.claimType = "workInjury"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
