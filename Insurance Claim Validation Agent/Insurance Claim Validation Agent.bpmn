            </zeebe:ioMapping>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_0njq9d7</bpmn:incoming>
        </bpmn:intermediateThrowEvent>
        <bpmn:sequenceFlow id="Flow_0njq9d7" sourceRef="Event_1njx6dg" targetRef="Event_11lexz4" />
      </bpmn:subProcess>
      <bpmn:sequenceFlow id="Flow_0qfo9kt" sourceRef="Gateway_1g2q0zh" targetRef="Event_0m8dzxr" />
